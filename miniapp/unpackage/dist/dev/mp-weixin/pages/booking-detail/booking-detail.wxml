<view class="container data-v-7b0bce26"><view class="{{['status-card','data-v-7b0bce26',statusClass]}}"><text class="status-text data-v-7b0bce26">{{statusText}}</text><text class="booking-no data-v-7b0bce26">{{"预约单号: "+currentBooking?.bookingNo}}</text></view><view class="info-card data-v-7b0bce26"><view class="info-row data-v-7b0bce26"><text class="label data-v-7b0bce26">球馆</text><text class="value data-v-7b0bce26">{{currentBooking?.venueName}}</text></view><view class="info-row data-v-7b0bce26"><text class="label data-v-7b0bce26">场地</text><text class="value data-v-7b0bce26">{{currentBooking?.courtName}}</text></view><view class="info-row data-v-7b0bce26"><text class="label data-v-7b0bce26">日期</text><text class="value data-v-7b0bce26">{{currentBooking?.bookingDate}}</text></view><view class="info-row data-v-7b0bce26"><text class="label data-v-7b0bce26">时段</text><text class="value data-v-7b0bce26">{{currentBooking?.startTime+" - "+currentBooking?.endTime}}</text></view><view class="info-row data-v-7b0bce26"><text class="label data-v-7b0bce26">创建时间</text><text class="value data-v-7b0bce26">{{$root.m0}}</text></view></view><block wx:if="{{currentBooking?.status===1}}"><view class="qr-section data-v-7b0bce26"><view data-event-opts="{{[['tap',[['refreshQrCodeData',['$event']]]]]}}" class="qr-container data-v-7b0bce26" bindtap="__e"><block wx:if="{{qrCodeUrl}}"><image class="qr-code data-v-7b0bce26" src="{{qrCodeUrl}}" mode="aspectFit"></image></block><block wx:else><view class="qr-placeholder data-v-7b0bce26"><text class="data-v-7b0bce26">点击获取核销码</text></view></block></view><text class="qr-tip data-v-7b0bce26">请在核销窗口内向场馆员出示此码</text><block wx:if="{{qrExpireAt}}"><text class="qr-expire data-v-7b0bce26">{{'有效期至: '+$root.m1+''}}</text></block><button data-event-opts="{{[['tap',[['refreshQrCodeData',['$event']]]]]}}" class="refresh-btn data-v-7b0bce26" bindtap="__e">刷新核销码</button></view></block><block wx:if="{{currentBooking?.status===1}}"><view class="actions data-v-7b0bce26"><button data-event-opts="{{[['tap',[['handleCancelBooking',['$event']]]]]}}" class="cancel-btn data-v-7b0bce26" bindtap="__e">取消预约</button></view></block><block wx:if="{{currentBooking?.status===2}}"><view class="cancel-info data-v-7b0bce26"><text class="cancel-reason data-v-7b0bce26">{{"取消原因: "+(currentBooking?.cancelReason||'用户取消')}}</text><text class="cancel-time data-v-7b0bce26">{{"取消时间: "+$root.m2}}</text></view></block><block wx:if="{{currentBooking?.status===3}}"><view class="checkin-info data-v-7b0bce26"><text class="checkin-time data-v-7b0bce26">{{"签到时间: "+$root.m3}}</text></view></block></view>