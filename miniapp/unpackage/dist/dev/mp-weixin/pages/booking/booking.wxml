<view class="container data-v-54bc03ba"><view class="venue-info data-v-54bc03ba"><text class="venue-name data-v-54bc03ba">{{currentVenue?.name}}</text><text class="court-name data-v-54bc03ba">{{court?.name}}</text></view><view class="date-picker data-v-54bc03ba"><scroll-view class="date-scroll data-v-54bc03ba" scroll-x="{{true}}"><block wx:for="{{dateList}}" wx:for-item="date" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['selectDate',['$0'],[[['dateList','',index,'value']]]]]]]}}" class="{{['date-item','data-v-54bc03ba',(selectedDate===date.value)?'active':'']}}" bindtap="__e"><text class="date-week data-v-54bc03ba">{{date.week}}</text><text class="date-day data-v-54bc03ba">{{date.day}}</text></view></block></scroll-view></view><view class="slots-container data-v-54bc03ba"><view class="slots-header data-v-54bc03ba"><text class="data-v-54bc03ba">选择时段</text><view class="legend data-v-54bc03ba"><text class="legend-item free data-v-54bc03ba">可预约</text><text class="legend-item occupied data-v-54bc03ba">已占用</text></view></view><view class="slots-grid data-v-54bc03ba"><block wx:for="{{$root.l0}}" wx:for-item="slot" wx:for-index="__i0__" wx:key="startTime"><view data-event-opts="{{[['tap',[['toggleSlot',['$0'],[[['slots','startTime',slot.$orig.startTime]]]]]]]}}" class="{{['slot-item','data-v-54bc03ba',(slot.$orig.status==='free')?'free':'',(slot.$orig.status==='occupied')?'occupied':'',(slot.m0)?'selected':'']}}" bindtap="__e"><text class="slot-time data-v-54bc03ba">{{slot.m1}}</text></view></block></view><block wx:if="{{$root.g0}}"><view class="empty data-v-54bc03ba"><text class="data-v-54bc03ba">暂无时段数据</text></view></block></view><view class="footer data-v-54bc03ba"><view class="selected-info data-v-54bc03ba"><block wx:if="{{$root.g1>0}}"><text class="data-v-54bc03ba">{{'已选: '+$root.m2+" - "+$root.m3+''}}</text></block><block wx:else><text class="data-v-54bc03ba">请选择时段</text></block></view><button class="submit-btn data-v-54bc03ba" disabled="{{$root.g2}}" data-event-opts="{{[['tap',[['submitBooking',['$event']]]]]}}" bindtap="__e">{{''+(submitting?'提交中...':'立即预约')+''}}</button></view></view>